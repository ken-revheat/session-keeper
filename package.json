{
  "name": "@revheat/session-keeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./core": { "types": "./dist/core.d.ts", "default": "./dist/core.js" },
    "./react": { "types": "./dist/react.d.ts", "default": "./dist/react.js" },
    "./nuxt": { "types": "./dist/nuxt.d.ts", "default": "./dist/nuxt.js" }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
